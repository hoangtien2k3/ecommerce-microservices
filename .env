# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD="ecommerce@!@#"

# ============================================================
# Redis
# ============================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD="ecommerce@!@#"

# ============================================================
# Kafka
# ============================================================
KAFKA_SERVERS=localhost:9092

# ============================================================
# Keycloak
# ============================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD="ecommerce@!@#"
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=ecommerce
KEYCLOAK_CLIENT_ID=ecommerce-client
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_ADMIN_REALM=master
KEYCLOAK_ADMIN_CLIENT_ID=admin-cli
KEYCLOAK_ADMIN_USERNAME=admin
JWT_ISSUER_URI=http://localhost:8080/realms/ecommerce
KEYCLOAK_JWK_SET_URI=http://localhost:8080/realms/ecommerce/protocol/openid-connect/certs

# ============================================================
# Object Storage (RustFS - S3 compatible)
# ============================================================
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=rustfsadmin
STORAGE_SECRET_KEY=rustfsadmin
STORAGE_BUCKET=ecommerce-media

# ============================================================
# Elasticsearch
# ============================================================
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ============================================================
# Zipkin
# ============================================================
ZIPKIN_URL=http://localhost:9411

# ============================================================
# Eureka
# ============================================================
EUREKA_URI=http://localhost:8761/eureka

# ============================================================
# Mail (Gmail App Password)
# ============================================================
MAIL_USERNAME=hoangtien2k3qx1@yopmail.com
MAIL_PASSWORD="ecommerce@!@#"

# ============================================================
# App version (used in OpenAPI / Swagger UI)
# ============================================================
APP_VERSION=v1

# ============================================================
# Security (common-spring BaseSecurityConfig)
# ============================================================
ECOMMERCE_SECURITY_ENABLED=true
ECOMMERCE_SECURITY_CSRF_DISABLED=true
ECOMMERCE_SECURITY_STATELESS_SESSION=true

# ============================================================
# CORS (common-spring CorsAutoConfigurer)
# ============================================================
ECOMMERCE_CORS_ENABLED=true
CORS_ALLOWED_ORIGIN_PATTERNS=*
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE_SECONDS=3600

# ============================================================
# RestClient connection pool (common-spring RestClientAutoConfiguration)
# ============================================================
REST_CLIENT_CONNECT_TIMEOUT=5s
REST_CLIENT_READ_TIMEOUT=30s
REST_CLIENT_POOL_MAX_TOTAL=200
REST_CLIENT_POOL_MAX_PER_ROUTE=50
REST_CLIENT_POOL_KEEP_ALIVE=60s
REST_CLIENT_POOL_EVICT_IDLE_AFTER=30s

# ============================================================
# i18n (common-spring I18nAutoConfiguration)
# ============================================================
I18N_DEFAULT_LOCALE=vi
I18N_CACHE_DURATION=1h

# ============================================================
# Web cross-cutters (common-spring WebAutoConfiguration)
# ============================================================
WEB_CORRELATION_ENABLED=true
WEB_EXCEPTION_HANDLER_ENABLED=true

# ============================================================
# HTTP Logging (HttpLoggingFilter + LoggerAspect)
# ============================================================
HTTP_LOG_REQUEST_ENABLED=true
HTTP_LOG_REQUEST_BODY=true
HTTP_LOG_REQUEST_MAX_BYTES=2048
HTTP_LOG_RESPONSE_ENABLED=true
HTTP_LOG_RESPONSE_BODY=false
HTTP_LOG_RESPONSE_MAX_BYTES=2048
HTTP_LOG_PERF_ENABLED=true
HTTP_LOG_PERF_THRESHOLD_MS=50

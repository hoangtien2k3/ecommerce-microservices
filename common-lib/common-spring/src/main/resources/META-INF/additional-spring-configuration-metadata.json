{
  "groups": [
    { "name": "ecommerce.cors",                   "description": "Cross-origin resource sharing." },
    { "name": "ecommerce.i18n",                   "description": "i18n message-source configuration." },
    { "name": "ecommerce.openapi",                "description": "OpenAPI metadata (title, version, description)." },
    { "name": "ecommerce.web.correlation",        "description": "X-Correlation-Id / X-Request-Id propagation filter." },
    { "name": "ecommerce.web.exception-handler",  "description": "Global RestControllerAdvice → ApiResponse envelope." },
    { "name": "ecommerce.web.logging",            "description": "HTTP access log settings." },
    { "name": "ecommerce.web.logging.request",    "description": "Inbound request log settings." },
    { "name": "ecommerce.web.logging.response",   "description": "Outbound response log settings." }
  ],
  "properties": [
    {
      "name": "ecommerce.cors.enabled",
      "type": "java.lang.Boolean",
      "description": "Enable platform CORS filter.",
      "defaultValue": true
    },
    {
      "name": "ecommerce.web.correlation.enabled",
      "type": "java.lang.Boolean",
      "description": "Enable correlation-id filter.",
      "defaultValue": true
    },
    {
      "name": "ecommerce.web.exception-handler.enabled",
      "type": "java.lang.Boolean",
      "description": "Enable the platform RestControllerAdvice.",
      "defaultValue": true
    },
    {
      "name": "ecommerce.web.logging.request.enabled",
      "type": "java.lang.Boolean",
      "description": "Enable HTTP request logging.",
      "defaultValue": true
    },
    {
      "name": "ecommerce.web.logging.request.include-body",
      "type": "java.lang.Boolean",
      "description": "Include request body in the log line.",
      "defaultValue": true
    },
    {
      "name": "ecommerce.web.logging.request.max-body-bytes",
      "type": "java.lang.Integer",
      "description": "Maximum bytes to log from the request body.",
      "defaultValue": 2048
    },
    {
      "name": "ecommerce.web.logging.response.enabled",
      "type": "java.lang.Boolean",
      "description": "Enable HTTP response logging.",
      "defaultValue": true
    },
    {
      "name": "ecommerce.web.logging.response.include-body",
      "type": "java.lang.Boolean",
      "description": "Include response body in the log line. Off by default (can be large).",
      "defaultValue": false
    },
    {
      "name": "ecommerce.web.logging.response.max-body-bytes",
      "type": "java.lang.Integer",
      "description": "Maximum bytes to log from the response body.",
      "defaultValue": 2048
    }
  ]
}

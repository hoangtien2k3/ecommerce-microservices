# ─────────────────────────────────────────────────────────────────────────────
# @ecommerce/web — environment config
# Loaded by Next.js automatically. Precedence: .env.local > .env (this file).
# NOTE: this file is git-ignored. Commit values via .env.example instead.
# ─────────────────────────────────────────────────────────────────────────────

# Public API gateway (APISIX) origin the BROWSER calls. Must start with
# NEXT_PUBLIC_ to be exposed client-side. Point it at whatever backend is running:
#   - k8s cluster up (start-ecommerce.sh):  http://api.ecommerce.local
#   - backend via docker-compose locally:   http://localhost:8080
# The homepage runs on mock data, so it renders even with NO backend reachable.
NEXT_PUBLIC_API_URL=http://api.ecommerce.local

# Dev server port (also set in package.json "dev" script).
PORT=3000
